# Maintainer: Ron Hinchley <commuted@gmail.com>
pkgname=poetit
pkgver=0.1.0
pkgrel=1
pkgdesc="Desktop poetry editor with meter analysis, rhyme lookup, thesaurus, and version control"
arch=('any')
url="https://github.com/commuted/poetit"
license=('MIT')
# Mirrors the required dependencies in pyproject.toml [project].dependencies.
depends=(
    'python>=3.10'
    'tk'
    'python-nltk'
    'python-prosodic'
    'python-ufal-udpipe'
    'python-dulwich'
    'python-resvg-py'
    'python-pillow'
    'python-pyspellchecker'
)
makedepends=(
    'python-build'
    'python-installer'
    'python-wheel'
    'python-setuptools'
)
optdepends=(
    # "quality" extra: more accurate diagram via Stanza's biaffine parser;
    # pulls PyTorch (~1.7 GB) and downloads its EWT model on first use. Without
    # it the diagram uses the bundled UDPipe model.
    'python-stanza: improved dependency-diagram accuracy (quality mode)'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/commuted/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')   # replace with actual sha256 before AUR submission

build() {
    cd "$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 NOTICE  "$pkgdir/usr/share/licenses/$pkgname/NOTICE"
    install -Dm644 poetit/data/icon.png \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/$pkgname.png"
    install -Dm644 poetit/data/icon.png \
        "$pkgdir/usr/share/icons/hicolor/512x512/apps/$pkgname.png"
    install -Dm644 poetit/data/poetit.desktop \
        "$pkgdir/usr/share/applications/$pkgname.desktop"
}
