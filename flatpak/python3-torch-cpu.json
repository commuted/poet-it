{
  "name": "python3-torch-cpu",
  "comment": "Hand-written module: installs the CPU-only torch wheel from download.pytorch.org/whl/cpu instead of the ~4.5 GB CUDA build that PyPI serves. Must be listed BEFORE python3-requirements.json so the pre-installed torch satisfies stanza's torch>=1.13 requirement (generate-pip-sources.sh ignores torch). Torch is installed with --no-deps to sidestep its setuptools<82 pin; its runtime deps are installed explicitly below. Bump the wheel here when stanza's torch floor moves; wheel URLs + sha256 come from the index page https://download.pytorch.org/whl/cpu/torch/",
  "buildsystem": "simple",
  "build-commands": [
    "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} --no-deps --no-build-isolation torch sympy mpmath networkx jinja2 markupsafe filelock fsspec typing_extensions"
  ],
